# ============================================================
# SANAD - Variables d'environnement (modele)
# Copiez ce fichier vers `.env` et remplissez vos propres cles.
# NE COMMITEZ JAMAIS le fichier `.env` reel.
# ============================================================

# --- LLM Cloud (Groq) : chat FNOL, extraction documents, vision ---
# Cle gratuite : https://console.groq.com/keys
GROQ_API_KEY=gsk_votre_cle_groq_ici
# Optionnel : surcharger les modeles par defaut
# GROQ_MODEL=openai/gpt-oss-120b
# GROQ_VISION_MODEL=qwen/qwen3.6-27b

# --- Base de donnees MongoDB ---
MONGODB_URI=mongodb://127.0.0.1:27017/sanad

# --- Authentification (JWT + bootstrap assureur) ---
JWT_SECRET=changez-moi-avec-une-chaine-aleatoire-longue
SETUP_SECRET=changez-moi-secret-de-setup
INSURER_EMAIL=insurer@sanad.tn
INSURER_PASSWORD=ChangezCeMotDePasse!

# --- Service OCR/eKYC Python (FastAPI, port 8001) ---
NEXT_PUBLIC_OCR_API_URL=http://localhost:8001
OCR_SERVICE_URL=http://localhost:8001

# --- Envoi d'emails KYC (SMTP - ex. Gmail avec mot de passe d'application) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=votre_email@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_application
SMTP_SENDER=votre_email@gmail.com

# --- Detection de degats vehicule (Roboflow YOLO) ---
ROBOFLOW_API_KEY=votre_cle_roboflow
ROBOFLOW_MODEL=car-detection-damage/3
ROBOFLOW_API_URL=https://serverless.roboflow.com
